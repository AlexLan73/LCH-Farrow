#ifndef LFM_SIGNAL_GENERATOR_H
#define LFM_SIGNAL_GENERATOR_H

#include <vector>
#include <complex>
#include <cstddef>

/**
 * @brief Генератор ЛЧМ (Linear Frequency Modulation) сигналов
 *
 * Поддерживает:
 * - Целые задержки (integer delay_samples)
 * - Дробные задержки (fractional delay_samples) с интерполяцией
 * - Генерацию для одного луча или множества лучей с разными задержками
 */
class LFMSignalGenerator {
public:
    /**
     * @brief Конструктор
     * @param f_start Начальная частота (Hz)
     * @param f_stop Конечная частота (Hz)
     * @param sample_rate Частота дискретизации (Hz)
     * @param duration Длительность сигнала (sec)
     */
    LFMSignalGenerator(float f_start, float f_stop, 
                       float sample_rate, float duration);

    /**
     * @brief Сгенерировать ЛЧМ сигнал для одного луча с дробной задержкой
     * @param signal Указатель на выходной буфер
     * @param num_samples Количество отсчётов для генерации
     * @param delay_samples Задержка в отсчётах (может быть дробной)
     */
    void GenerateBeam(std::complex<float>* signal, 
                      size_t num_samples,
                      float delay_samples = 0.0f);

    /**
     * @brief Сгенерировать ЛЧМ сигналы для множества лучей
     * @param beams Вектор указателей на буферы лучей
     * @param num_samples Количество отсчётов на луч
     * @param num_beams Количество генерируемых лучей
     * @param delays Вектор задержек для каждого луча
     */
    void GenerateAllBeams(const std::vector<std::complex<float>*>& beams,
                          size_t num_samples, size_t num_beams,
                          const std::vector<float>& delays = {});

private:
    float f_start_;       ///< Начальная частота
    float f_stop_;        ///< Конечная частота
    float sample_rate_;   ///< Частота дискретизации
    float duration_;      ///< Длительность сигнала
};

#endif // LFM_SIGNAL_GENERATOR_H
